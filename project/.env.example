# Next.js Configuration
# Copy this file to .env.local and fill in your values
# Run: cp .env.example .env.local

# ============================================
# CLERK AUTHENTICATION (Task 2.1)
# ============================================
# Get your keys from https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Clerk URLs (update these after deploying)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# DATABASE (Task 3.2)
# ============================================
# Option 1: Vercel Postgres
# POSTGRES_URL=your_vercel_postgres_url
# POSTGRES_PRISMA_URL=your_vercel_postgres_prisma_url
# POSTGRES_URL_NON_POOLING=your_vercel_postgres_non_pooling_url

# Option 2: Neon Database
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Option 3: Local PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/projectflow

# ============================================
# OPTIONAL: DEVELOPMENT
# ============================================
# NODE_ENV=development

# ============================================
# NOTES FOR INTERNS
# ============================================
# - Never commit .env.local to git (it's in .gitignore)
# - Store sensitive keys securely
# - Use different keys for development and production
# - Get production keys from your team lead during deployment phase
